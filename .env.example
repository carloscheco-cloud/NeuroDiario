# ── WordPress ──────────────────────────────────────────────────────────────────
WORDPRESS_URL=https://ejemplo.com
WORDPRESS_USER=usuario
WORDPRESS_PASSWORD=contraseña

# ── Base de Datos (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost/neurodiario

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Alias alternativo (también soportado)
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6

# ── Aplicación ─────────────────────────────────────────────────────────────────
DEBUG=False
LOG_LEVEL=INFO
TIMEZONE=America/Santo_Domingo

# ── Pipeline ───────────────────────────────────────────────────────────────────
FETCH_INTERVAL_HOURS=2
MAX_ARTICLES_PER_CYCLE=100
TREND_WINDOW_HOURS=24
INGESTION_INTERVAL_MINUTES=15
NLP_INTERVAL_MINUTES=20

# ── NLP ────────────────────────────────────────────────────────────────────────
SPACY_MODEL=es_core_news_lg
